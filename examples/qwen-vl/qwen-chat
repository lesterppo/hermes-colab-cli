def cmd_login(args):
    if len(args) < 1:
        die("Usage: qwen-chat login <url> [name]")
    url = args[0].rstrip("/")
    name = args[1] if len(args) > 1 else "default"

    print(f"Testing {url}...")
    ok, health = health_check(url)
    if not ok:
        die(f"Cannot reach server: {health.get('error', url)}")
    print(f"  Model: {health.get('model','?')}  VRAM: {health.get('vram_gb','?')} GB  Status: ok")

    cfg = load_config()
    cfg["accounts"][name] = {"url": url, "added": _now()}
    if cfg["active"] is None:
        cfg["active"] = name
    save_config(cfg)
    print(f"Account '{name}' saved. Active: {cfg['active']}")
    _save_session(name, "default")

def cmd_reconnect(args):
    """Force redeploy + reconnect."""
    cfg = load_config()
    name = cfg.get("active", "default")
    print(f"Redeploying for '{name}'...")
    new_url = colab_deploy("qwen-vl")
    if new_url:
        cfg["accounts"][name] = {"url": new_url, "added": _now()}
        cfg["active"] = name
        save_config(cfg)
        print(f"Done. Active: {name} → {new_url}")
    else:
        die("Redeploy failed. Check Colab quota / auth.")

def cmd_list(args):
    cfg = load_config()
    if not cfg["accounts"]:
        print("No accounts. Use: qwen-chat login <url> [name]")
        return
    active = cfg.get("active","")
    for name, acct in cfg["accounts"].items():
        marker = f"{GREEN} *{RESET}" if name == active else "  "
        print(f"{marker} {name}: {acct['url']}  {DIM}({acct.get('added','?')}){RESET}")

def cmd_switch(args):
    if len(args) < 1: die("Usage: qwen-chat switch <name>")
    name = args[0]
    cfg = load_config()
    if name not in cfg["accounts"]: die(f"Account '{name}' not found.")
    cfg["active"] = name
    save_config(cfg)
    print(f"Active: {name} → {cfg['accounts'][name]['url']}")

def cmd_chat(args):
    if len(args) < 1: die("Usage: qwen-chat chat <prompt>")
    text = " ".join(args)
    cfg = load_config()
    name, acct = get_active(cfg)
    sid = _get_session(name)
    print(f"{DIM}[{name}]{RESET} ", end="", flush=True)
    resp = api_call(acct["url"], "/chat", {
        "text": text, "session_id": sid, "max_tokens": 512, "temperature": 0.7
    })
    print(resp["response"])

def cmd_image(args):
    if len(args) < 2: die("Usage: qwen-chat image <path> <prompt>")
    image_path = os.path.expanduser(args[0])
    b64, err = encode_image(image_path)
    if err: die(err)
    cfg = load_config()
    name, acct = get_active(cfg)
    sid = _get_session(name)
    print(f"{DIM}[{name} + {os.path.basename(image_path)}]{RESET} ", end="", flush=True)
    resp = api_call(acct["url"], "/chat", {
        "text": " ".join(args[1:]), "images": [b64],
        "session_id": sid, "max_tokens": 512, "temperature": 0.7
    })
    print(resp["response"])

def cmd_status(args):
    cfg = load_config()
    name, acct = get_active(cfg)
    ok, h = health_check(acct["url"])
    print(f"Account:  {name}")
    print(f"URL:      {acct['url']}")
    if ok:
        print(f"Model:    {h.get('model','?')}")
        print(f"VRAM:     {h.get('vram_gb','?')} GB")
        print(f"Uptime:   {h.get('uptime_s',0)//60}m")
        print(f"Sessions: {h.get('active_sessions','?')}")
        print(f"Session:  {_get_session(name)}")
    else:
        print(f"Status:   {RED}OFFLINE{RESET} — {h.get('error','?')}")

def cmd_remove(args):
    if len(args) < 1: die("Usage: qwen-chat remove <name>")
    name = args[0]
    cfg = load_config()
    if name not in cfg["accounts"]: die(f"'{name}' not found.")
    del cfg["accounts"][name]
    if cfg["active"] == name:
        cfg["active"] = next(iter(cfg["accounts"]), None)
    save_config(cfg)
    print(f"Removed '{name}'. Active: {cfg['active'] or '(none)'}")

def cmd_reset(args):
    cfg = load_config()
    name, acct = get_active(cfg)
    sid = _get_session(name)
    api_call(acct["url"], f"/reset?session_id={sid}", method="POST")
    print(f"Session '{sid}' cleared.")

def cmd_session(args):
    cfg = load_config()
    if len(args) < 1:
        name = cfg.get("active","none")
        print(f"Account: {name}  Session: {_get_session(name) if name!='none' else 'N/A'}")
        return
    active = cfg.get("active","default")
    _save_session(active, args[0])
    print(f"Session for '{active}': {args[0]}")

def cmd_help(args):
    print(__doc__.strip())

def cmd_drive_link(args):
    """Set model cache URL for fast redeploys (~30s vs ~3min).

    URL must be a DIRECT download link (not a file-host download page).
    Works with: Google Drive share links (gdown), any direct HTTP tar.gz URL.
    Does NOT work with: gofile.io download pages, any JS-required file hosts.

    To create a cache manually:
      1. Download model once on Colab (creates /content/qwen-vl-cache.tar.gz)
      2. Upload to any direct-download host
      3. Set URL here: qwen-chat drive-link <url>

    Recommended: Use HF_TOKEN instead (free, no hosting needed):
      qwen-chat hf-token <token>
    """
    if len(args) < 1:
        cfg = load_config()
        link = cfg.get("drive_url", "")
        if link:
            print(f"Cache URL: {link}")
        else:
            print("No cache URL configured.")
            print()
            print("Options for faster deploys:")
            print(f"  1. {BOLD}HF_TOKEN{RESET} (recommended): qwen-chat hf-token <token>")
            print(f"     Get free token: https://huggingface.co/settings/tokens")
            print(f"  2. Cache URL: qwen-chat drive-link <direct-download-url>")
            print(f"     Host model cache tar.gz on any direct-download server")
        return
    cfg = load_config()
    cfg["drive_url"] = args[0]
    save_config(cfg)
    print(f"Cache URL saved. Next reconnect will use it (if direct-download).")
    if "gofile.io/d/" in args[0]:
        print(f"{YELLOW}WARNING:{RESET} gofile.io download pages require JS. May not work.")
        print(f"  Use a direct download URL instead, or set HF_TOKEN.")

def cmd_hf_token(args):
    """Set HuggingFace token for fast authenticated downloads."""
    if len(args) < 1:
        cfg = load_config()
        token = cfg.get("hf_token", "")
        if token:
            print(f"HF_TOKEN: {token[:8]}...{token[-4:] if len(token) > 12 else ''}")
        else:
            print("No HF_TOKEN configured.")
            print("Get one at: https://huggingface.co/settings/tokens")
            print("Then: qwen-chat hf-token <token>")
        return
    cfg = load_config()
    cfg["hf_token"] = args[0]
    save_config(cfg)
    print(f"HF_TOKEN saved. Redeploys will use authenticated downloads (~5x faster).")

# ── Dispatch ──────────────────────────────────────────────────────────

COMMANDS = {
    "login": cmd_login, "reconnect": cmd_reconnect, "list": cmd_list,
    "switch": cmd_switch, "chat": cmd_chat, "image": cmd_image,
    "status": cmd_status, "remove": cmd_remove, "reset": cmd_reset,
    "session": cmd_session, "repl": cmd_repl,
    "drive-link": cmd_drive_link, "hf-token": cmd_hf_token,
    "help": cmd_help, "-h": cmd_help, "--help": cmd_help,
}

if __name__ == "__main__":
    if len(sys.argv) < 2:
        cmd_repl([])
    else:
        cmd = sys.argv[1]
        if cmd in COMMANDS:
            COMMANDS[cmd](sys.argv[2:])
        else:
            print(f"Unknown: {cmd}. Available: {', '.join(COMMANDS.keys())}", file=sys.stderr)
            sys.exit(1)
