# REPL
# ═══════════════════════════════════════════════════════════════════════

def cmd_repl(args):
    cfg = load_config()
    name, acct = get_active(cfg)
    sid = _get_session(name)

    # Pre-flight health check with auto-reconnect
    ok, health = health_check(acct["url"])
    if not ok:
        print(f" {YELLOW}Server unreachable — attempting auto-reconnect...{RESET}")
        new_url = colab_deploy("qwen-vl")
        if new_url:
            cfg["accounts"][name]["url"] = new_url
            save_config(cfg)
            acct["url"] = new_url
            ok, health = health_check(new_url)
        if not ok:
            die(f"Cannot reach server. Run: qwen-chat reconnect\n  {health.get('error', '')}")

    # Banner
    print()
    print(_rule("═"))
    print(f" {BOLD}Qwen Chat{RESET}  {DIM}— {health.get('model', '?')}{RESET}")
    print(f" {DIM}Account:{RESET} {name}  {DIM}Session:{RESET} {sid}  "
          f"{DIM}VRAM:{RESET} {health.get('vram_gb', '?')} GB  "
          f"{DIM}Uptime:{RESET} {health.get('uptime_s', 0)//60}m")
    print(_rule("═"))
    print(f" {DIM}Chat away. /image <path>  /help  /quit{RESET}")
    print()

    pending_image = None
    history = []

    def on_sigint(sig, frame):
        print(f"\n{YELLOW}Interrupted. /quit to exit.{RESET}")
    prev_handler = signal.signal(signal.SIGINT, on_sigint)

    try:
        while True:
            prompt = f"{CYAN}🖼 {os.path.basename(pending_image)} ▸{RESET} " if pending_image else f"{CYAN}▸{RESET} "

            try:
                line = input(prompt)
            except EOFError:
                print()
                break

            line = line.strip()
            if not line:
                continue

            # ── /commands ──────────────────────────────────────────
            if line.startswith("/"):
                parts = line.split(maxsplit=1)
                cmd = parts[0].lower()
                arg = parts[1] if len(parts) > 1 else ""

                if cmd in ("/quit", "/exit", "/q"):
                    break

                elif cmd == "/help":
                    print(f"\n {BOLD}Commands{RESET}")
                    print(f" {DIM}{'─'*40}{RESET}")
                    for c, d in [
                        ("/image <path>","Attach image to next message"),
                        ("/reconnect",   "Force redeploy Colab session"),
                        ("/reset",       "Clear conversation history"),
                        ("/status",      "Show server info"),
                        ("/session <id>","Switch session"),
                        ("/help",        "Show this"),
                        ("/quit",        "Exit"),
                    ]:
                        print(f" {CYAN}{c:<16}{RESET} {d}")
                    print()

                elif cmd == "/image":
                    if not arg:
                        print(f" {RED}Usage:{RESET} /image <path>")
                        continue
                    img_path = os.path.expanduser(arg)
                    b64, err = encode_image(img_path)
                    if err:
                        print(f" {RED}{err}{RESET}")
                        continue
                    pending_image = img_path
                    size_mb = os.path.getsize(img_path) / 1e6
                    print(f" {GREEN}✓{RESET} {os.path.basename(img_path)} ({size_mb:.1f}MB) attached. Type prompt.")

                elif cmd == "/reconnect":
                    print(f" {YELLOW}⟳{RESET} Force reconnecting...")
                    new_url = colab_deploy("qwen-vl")
                    if new_url:
                        cfg["accounts"][name]["url"] = new_url
                        save_config(cfg)
                        acct["url"] = new_url
                        print(f" {GREEN}✓{RESET} Reconnected: {new_url}")
                    else:
                        print(f" {RED}✗{RESET} Reconnect failed.")

                elif cmd == "/reset":
                    try:
                        api_call(acct["url"], f"/reset?session_id={sid}", method="POST")
                    except: pass
                    history = []
                    pending_image = None
                    print(f" {GREEN}✓{RESET} Cleared.")

                elif cmd == "/status":
                    ok, h = health_check(acct["url"])
                    if ok:
                        print(f" {DIM}Model:{RESET}   {h.get('model','?')}")
                        print(f" {DIM}VRAM:{RESET}    {h.get('vram_gb','?')} GB")
                        print(f" {DIM}Uptime:{RESET}  {h.get('uptime_s',0)//60}m")
                        print(f" {DIM}Session:{RESET} {sid}  {DIM}Turns:{RESET} {len(history)//2}")
                    else:
                        print(f" {RED}Offline:{RESET} {h.get('error','?')}")

                elif cmd == "/session":
                    if not arg:
                        print(f" {DIM}Session:{RESET} {sid}")
                        continue
                    _save_session(name, arg)
                    sid = arg
                    history = []
                    pending_image = None
                    print(f" {GREEN}✓{RESET} Session '{sid}'.")

                else:
                    print(f" {RED}?{RESET} {cmd}. /help for commands.")
                continue

            # ── Send to model ──────────────────────────────────────
            images_b64 = None
            image_label = ""
            if pending_image:
                b64, _ = encode_image(pending_image)
                images_b64 = [b64]
                image_label = f" {DIM}[{os.path.basename(pending_image)}]{RESET}"
                pending_image = None

            print(f"\n {CYAN}{BOLD}You:{RESET}{image_label} {line}")
            print(f" {DIM}{'─' * min(_term_width()-2, 60)}{RESET}")
            print(f" {DIM}⏳{RESET}", end="\r", flush=True)

            try:
                resp = api_call(acct["url"], "/chat", {
                    "text": line, "images": images_b64,
                    "session_id": sid, "max_tokens": 1024, "temperature": 0.7,
                })
            except ConnectionError as e:
                print(f"\n {RED}✗{RESET} {e}")
                continue
            except Exception as e:
                print(f"\n {RED}✗{RESET} {e}")
                continue

            response_text = resp["response"]
            width = _term_width() - 2
            wrapped = textwrap.fill(response_text, width=width)

            print(f" {GREEN}{BOLD}Qwen:{RESET}")
            for line_out in wrapped.split("\n"):
                print(f" {line_out}")
            print()

            history.append(("user", line, pending_image))
            history.append(("assistant", response_text, None))

    except KeyboardInterrupt:
        print()
    finally:
        signal.signal(signal.SIGINT, prev_handler)
        print(f"\n {DIM}Session '{sid}' saved. Resume: qwen-chat{RESET}\n")


