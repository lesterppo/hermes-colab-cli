#!/usr/bin/env python3
"""qwen-chat v2 — CLI client for Qwen2.5-VL-3B Colab server.

Deploy times: ~3 min (standard), ~2 min (HF_TOKEN), ~30s (cache URL).
Auto-reconnect: if Colab runtime died, redeploys automatically.
Usage:
  qwen-chat                        Interactive REPL (default)
  qwen-chat login <url> [name]     Register endpoint
  qwen-chat reconnect [name]       Force redeploy + reconnect
  qwen-chat list                   List accounts
  qwen-chat switch <name>          Set active account
  qwen-chat chat <prompt>          One-shot text
  qwen-chat image <path> <prompt>  One-shot image + text
  qwen-chat status                 Server info
  qwen-chat remove <name>          Delete account
  qwen-chat reset                  Clear history
  qwen-chat session <name>         Switch session
  qwen-chat drive-link [url]       Set/view cache URL (direct download)
  qwen-chat hf-token [token]       Set/view HuggingFace token

REPL commands:
  /image <path>     Attach image to next message
  /reconnect        Force redeploy Colab session
  /reset            Clear conversation
  /status           Server info
  /session <id>     Switch session
  /help             Show commands
  /quit, /exit      Exit
"""

import json, os, sys, base64, urllib.request, urllib.error
import shutil, textwrap, subprocess, time, signal
from pathlib import Path

CONFIG_DIR = Path.home() / ".qwen-cli"
CONFIG_FILE = CONFIG_DIR / "accounts.json"
COLABC = str(Path.home() / ".hermes/scripts/colab/colab.py")
DEPLOY_SCRIPT = "/tmp/qwen-vl-deploy.py"

# ── Terminal colors ───────────────────────────────────────────────────

BOLD="\033[1m"; DIM="\033[2m"; RED="\033[31m"; GREEN="\033[32m"
YELLOW="\033[33m"; BLUE="\033[34m"; CYAN="\033[36m"; RESET="\033[0m"

def _term_width():
    return shutil.get_terminal_size().columns

def _rule(char="─", color=DIM):
    return color + char * _term_width() + RESET

# ── Config ────────────────────────────────────────────────────────────

def load_config():
    if CONFIG_FILE.exists():
        return json.loads(Path(CONFIG_FILE).read_text())
    return {"active": None, "accounts": {}}

def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2) + "\n")

def get_active(cfg):
    name = cfg.get("active")
    if not name:
        die("No active account. Use: qwen-chat login <url> [name]")
    acct = cfg["accounts"].get(name)
    if not acct:
        die(f"Active account '{name}' not found. Use: qwen-chat list")
    return name, acct

def die(msg):
    print(f"\n{RED}ERROR:{RESET} {msg}", file=sys.stderr)
    sys.exit(1)

# ── Colab management ──────────────────────────────────────────────────

def colab_cli(args, timeout=120):
    """Run colab.py with given args, return (ok, stdout)."""
    try:
        r = subprocess.run(
            ["python3", COLABC] + args,
            capture_output=True, text=True, timeout=timeout
        )
        return r.returncode == 0, (r.stdout + r.stderr)
    except subprocess.TimeoutExpired:
        return False, "timeout"
    except Exception as e:
        return False, str(e)

def colab_session_alive(session_name="qwen-vl"):
    """Check if Colab session exists and is active."""
    ok, out = colab_cli(["sessions"], timeout=15)
    return ok and session_name in out and "READY" in out or "IDLE" in out or "Running" in out

def colab_deploy(session_name="qwen-vl"):
    """Create session, upload deploy script, wait for tunnel URL. Returns URL or None."""
    print(f" {YELLOW}⟳{RESET} Creating Colab session with T4 GPU...")

    # Step 0: Stop any existing session with same name
    ok, out = colab_cli(["sessions"], timeout=15)
    if ok and session_name in out:
        print(f" {DIM}  Stopping existing '{session_name}'...{RESET}")
        colab_cli(["stop", "-s", session_name], timeout=30)
        time.sleep(5)

    # Step 1: Create session
    ok, out = colab_cli(["new", "--gpu", "T4", "-s", session_name], timeout=120)
    if not ok:
        print(f" {RED}✗{RESET} Session creation failed: {out[:200]}")
        return None
    print(f" {GREEN}✓{RESET} Session '{session_name}' created.")

    # Step 2: Upload deploy config (DRIVE_URL, HF_TOKEN)
    cfg = load_config()
    deploy_cfg = {
        "DRIVE_URL": cfg.get("drive_url", ""),
        "HF_TOKEN": cfg.get("hf_token", ""),
    }
    cfg_file = CONFIG_DIR / "deploy_config.json"
    cfg_file.write_text(json.dumps(deploy_cfg))
    ok, out = colab_cli(["upload", "-s", session_name, str(cfg_file),
                          "/content/deploy_config.json"], timeout=30)

    # Step 3: Upload deploy script
    ok, out = colab_cli(["exec_detach", "-s", session_name, "-f", DEPLOY_SCRIPT,
                          "--log", "/content/deploy.log"], timeout=120)

    # Step 4: Upload check script
    check_script = "/tmp/check_deploy.py"
    if os.path.exists(check_script):
        colab_cli(["upload", "-s", session_name, check_script, "/content/check_deploy.py"], timeout=30)

    # Step 4: Wait for tunnel URL
    print(f" {YELLOW}⏳{RESET} Waiting for model to load (~3 min for fresh VM, ~40s for cached)...")
    for i in range(45):  # up to 15 min
        time.sleep(20)
        ok, out = colab_cli(["console", "-s", session_name, "--cmd",
                              "cat /content/api_url.txt 2>/dev/null || echo 'waiting'"], timeout=15)
        if ok and "trycloudflare.com" in out:
            url = out.strip().split("\n")[-1].strip()
            if "trycloudflare.com" in url:
                print(f" {GREEN}✓{RESET} Tunnel ready: {url}")
                return url
        # Show progress occasionally
        if i % 3 == 2 and ok:
            # Check deploy status
            ok2, status_out = colab_cli(["console", "-s", session_name, "--cmd",
                "cat /content/deploy_status.json 2>/dev/null || echo '{}'"], timeout=10)
            try:
                s = json.loads(status_out.split("\n")[0]) if status_out else {}
                stage = s.get("stage", "unknown")
                detail = s.get("detail", "")[:60]
                if stage not in ("ready", "running"):
                    print(f" {DIM}  Stage: {stage} — {detail}{RESET}")
            except: pass

    # Check what went wrong
    ok, log = colab_cli(["console", "-s", session_name, "--cmd",
                          "tail -20 /content/deploy.log 2>/dev/null"], timeout=10)
    print(f" {RED}✗{RESET} Tunnel not ready after 15 min.")
    print(f" {DIM}Last log:{RESET}\n{log[:500]}")
    return None

# ── API call with auto-reconnect ──────────────────────────────────────

def api_call(url, endpoint, data=None, method="POST", retry=True):
    """Make HTTP request. On connection failure, attempt auto-reconnect once."""
    full_url = f"{url.rstrip('/')}/{endpoint.lstrip('/')}"
    body = json.dumps(data).encode() if data else None
    req = urllib.request.Request(full_url, data=body, method=method)
    req.add_header("Content-Type", "application/json")

    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body_text = e.read().decode(errors="replace")
        raise ConnectionError(f"Server error {e.code}: {body_text[:300]}")
    except (urllib.error.URLError, OSError, ConnectionError) as e:
        if not retry:
            raise ConnectionError(f"Connection failed: {e}")
        # Auto-reconnect
        return _auto_reconnect_and_retry(url, endpoint, data, method)

def _auto_reconnect_and_retry(url, endpoint, data, method):
    """Attempt to redeploy and retry the request."""
    cfg = load_config()
    name = cfg.get("active")
    if not name:
        raise ConnectionError("No active account — cannot auto-reconnect.")

    print(f"\n {YELLOW}⟳ Connection lost. Auto-reconnecting...{RESET}")

    new_url = colab_deploy("qwen-vl")
    if not new_url:
        raise ConnectionError("Auto-reconnect failed. Run: qwen-chat reconnect")

    # Update config
    cfg["accounts"][name]["url"] = new_url
    save_config(cfg)
    print(f" {GREEN}✓{RESET} Reconnected. New endpoint: {new_url}")

    # Retry the original request (no more retries to avoid infinite loops)
    return api_call(new_url, endpoint, data, method, retry=False)

def health_check(url):
    """Quick health check. Returns (ok, info_dict)."""
    try:
        info = api_call(url, "/health", method="GET", retry=False)
        return True, info
    except Exception as e:
        return False, {"error": str(e)}

# ── Session helpers ───────────────────────────────────────────────────

def _get_session(account_name):
    sf = CONFIG_DIR / f"session_{account_name}.txt"
    return sf.read_text().strip() if sf.exists() else "default"

def _save_session(account_name, session_name):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    (CONFIG_DIR / f"session_{account_name}.txt").write_text(session_name)

def _now():
    from datetime import datetime
    return datetime.now().strftime("%Y-%m-%d")

def encode_image(path):
    if not os.path.exists(path):
        return None, f"Image not found: {path}"
    with open(path, "rb") as f:
        data = base64.b64encode(f.read()).decode()
    ext = os.path.splitext(path)[1].lower()
    mime_map = {".jpg":"jpeg", ".jpeg":"jpeg", ".png":"png",
                ".webp":"webp", ".gif":"gif", ".bmp":"bmp"}
    return f"data:image/{mime_map.get(ext, 'jpeg')};base64,{data}", None

